{
  "name": "toolrouter",
  "version": "0.1.0",
  "description": "A hierarchical tool router for LLM agents with too many tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/tests/*.test.js",
    "example:basic": "tsx examples/basic.ts",
    "example:no-tool": "tsx examples/no-tool.ts",
    "eval": "tsx evals/run-eval.ts",
    "eval:real": "tsx evals/run-real-eval.ts",
    "eval:large:real": "tsx evals/run-large-real-eval.ts"
  },
  "keywords": [
    "llm",
    "agents",
    "tools",
    "routing",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
